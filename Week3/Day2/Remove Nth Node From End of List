class Solution {
public:
    ListNode* removeNthFromEnd(ListNode* head, int n){
        ListNode* curr=new ListNode(0,head);
        ListNode* ans=curr;
        for(int i=0; i<n; i++){
            head=head->next;
        }
        while(head!=nullptr){
            head=head->next;
            ans=ans->next;
        }
        ans->next=ans->next->next;
        return curr->next;
    }
};
